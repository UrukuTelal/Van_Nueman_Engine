*.mp3
*.wav
*.png
*.jpg
*.jpeg
*.ttf
*.otf
*.glb
*.gltf
*.fbx
*.obj

# Asset directories (large binaries)
assets/images/
assets/audio/
assets/fonts/
assets/models/
assets/textures/

# Python virtual environments
env/
venv/
.venv/

# Environment files
.env
.env.local
.env.*

# Temp files
*.tmp
*.temp
