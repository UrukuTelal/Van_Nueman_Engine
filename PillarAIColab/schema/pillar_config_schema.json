{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "pillar_config_schema.json",
  "title": "Pillar Configuration Schema",
  "description": "Validates pillar config files for the PCMSRM AI agent system",
  "type": "object",
  "required": ["pillar_metadata", "operational_constants", "logic_mechanics", "failure_modes"],
  "properties": {
    "pillar_metadata": {
      "type": "object",
      "required": ["name", "index", "core_function", "description"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "index": {
          "type": "integer",
          "minimum": 0,
          "maximum": 15
        },
        "core_function": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "operational_constants": {
      "type": "object",
      "minProperties": 1
    },
    "logic_mechanics": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[a-z_]+$": {
          "type": "object",
          "required": ["formula", "impact"],
          "properties": {
            "formula": {"type": "string"},
            "impact": {"type": "string"},
            "interaction": {"type": "string"},
            "result": {"type": "string"}
          }
        }
      }
    },
    "failure_modes": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[a-z_]+$": {
          "type": "object",
          "required": ["condition", "result"],
          "properties": {
            "condition": {"type": "string"},
            "result": {"type": "string"}
          }
        }
      }
    }
  }
}
