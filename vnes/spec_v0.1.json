      "id": 7,
      "type": "hex",
      "description": "Primary conduit trunk passage (VNE-D)"
    },
    "UtilityTrunk": {
      "id": 8,
      "type": "hex",
      "description": "Cable and service trunk (VNE-E)"
    }
