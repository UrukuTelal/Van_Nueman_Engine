    "hex_hex": {
      "all_compatible": true,
      "note": "All hex faces are mechanically identical. Compatibility is always true."
    },
    "square_hex": {
      "all_incompatible": true,
      "note": "Square and hex faces have incompatible geometries and can never mate."
    }
