      "description": "Full structural load transfer (VNE-A)"
    },
    "StructuralFlange": {
      "id": 1,
      "type": "square",
      "description": "Flange connection for non-load-bearing cells (VNE-B/C)"
    },
    "StaticStructural": {
      "id": 2,
      "type": "square",
      "description": "Rigid non-load-bearing structural coupling (VNE-D)"
    },
    "StructuralSeal": {
      "id": 3,
      "type": "square",
      "description": "Sealed structural interface (VNE-E)"
    },
    "CapillaryFlow": {
      "id": 4,
      "type": "hex",
      "description": "Wicking and moisture transport (VNE-A)"
    },
    "FluidAirExchange": {
      "id": 5,
      "type": "hex",
      "description": "Air and water exchange for growth (VNE-B)"
    },
    "HydroponicFlow": {
      "id": 6,
      "type": "hex",
      "description": "Nutrient solution flow (VNE-C)"
